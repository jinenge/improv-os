# ===== 上游 LLM（必填）=====
# 任意 Anthropic /v1/messages 兼容端点：官方 API 或自建网关
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_AUTH_TOKEN=sk-ant-xxx    # 永不进前端、永不进 git
MODEL=claude-sonnet-4-6
MODEL_MODE=normal                  # normal=公司网关(Anthropic) / ai_gateway=ai.fzhiyu.dev(OpenAI兼容,推荐) / low_power=OpenRouter免费池
# --- ai_gateway 模式（推荐：自建 OpenAI 兼容网关，走 Cloudflare，快且便宜）---
AI_API_KEY=                        # ai_gateway 模式必填；永不进前端、永不进 git
AI_MODEL=gpt-5.3-codex-spark       # 实测 533 tok/s；ai.fzhiyu.dev 上其他可选见 /v1/models
AI_BASE_URL=https://ai.fzhiyu.dev/v1
# --- low_power 模式（OpenRouter 免费池，免费但不稳）---
OPENROUTER_API_KEY=                # 低功率模式必填；永不进前端、永不进 git
OPENROUTER_MODEL=openrouter/free   # 低功率模式默认免费路由器，也可换成具体 free 模型 id
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1   # 测试时可指向本地 mock
# MAX_TOKENS=12000                 # 单次生成输出上限

# ===== 服务 =====
# PORT=7100
# ALLOWED_ORIGINS=                 # 同源守卫额外白名单（逗号分隔域名；默认只放行本站/localhost）

# ===== 限流 / 成本闸（默认值即代码内置值）=====
# RATE_PER_HOUR=30                 # 单 IP 每小时生成数
# DAILY_CAP=3000                   # 全站每日生成总数熔断
# DAILY_TOKEN_BUDGET=0             # 全站每日 token 硬熔断；0=不限
# GEN_CONCURRENCY=5                # 快轨同时打上游的并发数（保护上游网关）
# GEN_QUEUE=24                     # 快轨排队上限，超出回「人数较多」
# LAN_GEN_CONCURRENCY=3            # 内网直连保底并发（独立闸门，公网打满也挤不掉内网；内网另免一切限流与同源守卫）
# LAN_GEN_QUEUE=16                 # 内网通道排队上限
# DEEP_QUEUE=8                     # 深轨（agent）排队上限，深轨并发恒为 1
# DEEP_TIMEOUT_SEC=150             # 深轨硬超时（秒）：挂死的 agent 自动中止，防止堵死唯一坑位（公网建议 300——复杂应用 150s 跑不完；opencode 请求空闲超时自动 = 此值+60s）
# UPSTREAM_MAX_RETRY=5             # 上游 429 指数退避重试次数
# CAP_AI_PER_MIN=20                # 能力桥 os.ai 每分钟限流（单 IP）
# CAP_HTTP_PER_MIN=30              # 能力桥 os.http 每分钟限流
# CAP_STORE_PER_MIN=120            # 能力桥 os.store 每分钟限流
# CAP_LIKE_PER_MIN=60              # 点赞接口每分钟限流（单 IP）
# CAP_COMPUTE_PER_MIN=30           # 形式原语 os.compute 每分钟限流（单 IP）；生成应用调它频率较高，默认 30
# MODERATED_APPIDS=                 # 受 AI 审核的 store 命名空间（公开留言墙等，逗号分隔 appId/slug）

# ===== 计费单价（元/百万 token，留空则成本面板显示「未配置」）=====
# 四类分开：未命中输入 / 输出 / 缓存读命中 / 缓存写。填上游网关真实单价即可在运维面板看到累计花费。
# PRICE_IN_PER_M=3                  # 未命中输入
# PRICE_OUT_PER_M=6                 # 输出
# PRICE_CACHE_READ_PER_M=0.3       # 缓存命中输入
# PRICE_CACHE_WRITE_PER_M=3.75     # 缓存写入

# ===== 慢轨（可选，需 opencode serve 常驻）=====
# OC_HOST=127.0.0.1
# OC_PORT=4096
# OC_PROVIDER=gateway              # 对应 opencode 配置里的 provider 键名（deploy/opencode.json）
# OC_MODEL=claude-sonnet-4-6

# ===== 内网运维控制台（可选，admin/server.mjs）=====
# ADMIN_PORT=7101
# ADMIN_TOKEN=                     # 留空则首次启动自动生成并写回本文件
# PUBLIC_URL=https://你的域名       # 控制台「公网端到端」健康检查的目标
# ALERT_WEBHOOK=                   # 健康脚本可选告警 webhook（deploy/healthcheck.sh）
