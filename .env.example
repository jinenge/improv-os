# ===== 上游 LLM（必填）=====
# 任意 Anthropic /v1/messages 兼容端点：官方 API 或自建网关
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_AUTH_TOKEN=sk-ant-xxx    # 永不进前端、永不进 git
MODEL=claude-sonnet-4-6
# MAX_TOKENS=12000                 # 单次生成输出上限

# ===== 服务 =====
# PORT=7100
# ALLOWED_ORIGINS=                 # 同源守卫额外白名单（逗号分隔域名；默认只放行本站/localhost）

# ===== 限流 / 成本闸（默认值即代码内置值）=====
# RATE_PER_HOUR=30                 # 单 IP 每小时生成数
# DAILY_CAP=3000                   # 全站每日生成总数熔断
# DAILY_TOKEN_BUDGET=0             # 全站每日 token 硬熔断；0=不限
# GEN_CONCURRENCY=5                # 快轨同时打上游的并发数（保护上游网关）
# GEN_QUEUE=24                     # 快轨排队上限，超出回「人数较多」
# DEEP_QUEUE=8                     # 深轨（agent）排队上限，深轨并发恒为 1
# DEEP_TIMEOUT_SEC=150             # 深轨硬超时（秒）：挂死的 agent 自动中止，防止堵死唯一坑位
# UPSTREAM_MAX_RETRY=5             # 上游 429 指数退避重试次数
# CAP_AI_PER_MIN=20                # 能力桥 os.ai 每分钟限流（单 IP）
# CAP_HTTP_PER_MIN=30              # 能力桥 os.http 每分钟限流
# CAP_STORE_PER_MIN=120            # 能力桥 os.store 每分钟限流

# ===== 慢轨（可选，需 opencode serve 常驻）=====
# OC_HOST=127.0.0.1
# OC_PORT=4096
# OC_PROVIDER=gateway              # 对应 opencode 配置里的 provider 键名（deploy/opencode.json）
# OC_MODEL=claude-sonnet-4-6

# ===== 内网运维控制台（可选，admin/server.mjs）=====
# ADMIN_PORT=7101
# ADMIN_TOKEN=                     # 留空则首次启动自动生成并写回本文件
# PUBLIC_URL=https://你的域名       # 控制台「公网端到端」健康检查的目标
# ALERT_WEBHOOK=                   # 健康脚本可选告警 webhook（deploy/healthcheck.sh）
